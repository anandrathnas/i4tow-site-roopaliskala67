---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { LoadingScreen } from '@/components/motion';
import { Nav } from '@/components/Nav';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteName = "Roopali's Kala Art Studio";
const fullTitle = title === siteName ? title : `${title} – ${siteName}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=DM+Sans:wght@400;500&display=swap"
    />
    <ClientRouter />
  </head>
  <body>
    <LoadingScreen client:load transition:persist />

    <Nav client:load />

    <main>
      <slot />
    </main>

    <footer class="border-t border-line bg-surface/50">
      <div class="mx-auto max-w-6xl px-6 py-12 text-sm text-ink-soft">
        <p class="font-display text-base text-ink">Roopali&rsquo;s Kala Art Studio</p>
        <p class="mt-2">Bay Area art classes for kids &amp; adults · Newark &amp; Fremont, CA</p>
      </div>
    </footer>
  </body>
</html>
