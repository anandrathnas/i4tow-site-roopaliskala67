---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BlockRenderer } from '@/components/blocks';
import type { Block } from '@/lib/blocks';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((p) => (p.data.slug ?? p.id) !== 'home')
    .map((p) => ({ params: { slug: p.data.slug ?? p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const blocks = (entry.data.blocks ?? []) as unknown as Block[];
---
<BaseLayout title={entry.data.title} description={entry.data.description} ogImage={entry.data.ogImage}>
  <BlockRenderer blocks={blocks} client:load />
</BaseLayout>
